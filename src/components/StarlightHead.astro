---
import Default from "@astrojs/starlight/components/Head.astro";

const { pathname } = Astro.url;
const blogMatch = pathname.match(/^\/blog\/(.+?)\/?$/);

let ogImage = "https://stalw.art/img/stalwart-social-card.jpg";
if (blogMatch && blogMatch[1] && !/^(authors|tags|\d+)$/.test(blogMatch[1])) {
  // Per-post OG image generated by /og/blog/<slug> (PNG response)
  ogImage = `https://stalw.art/og/blog/${blogMatch[1]}.png`;
}
---
<Default {...Astro.props}><slot /></Default>
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage} />
