---
import Default from "@astrojs/starlight/components/Head.astro";
import interLatinUrl from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";

const GTAG_ID = "G-NTKTV3G55G";
const SITE = Astro.site?.toString().replace(/\/$/, "") ?? "https://stalw.art";
const { pathname } = Astro.url;

// Per-blog-post OG image generated by /og/blog/<slug>.png; everything else
// falls back to the shared social card.
const blogMatch = pathname.match(/^\/blog\/(.+?)\/?$/);
let ogImage = `${SITE}/img/stalwart-social-card.jpg`;
if (blogMatch && blogMatch[1] && !/^(authors|tags|\d+)$/.test(blogMatch[1])) {
  ogImage = `${SITE}/og/blog/${blogMatch[1]}.png`;
}

// Pages that shouldn't be indexed:
//  - the archived 0.15 docs (current line is canonical)
//  - blog pagination, tags, authors (low-quality duplicates)
const isArchived = pathname.startsWith("/docs/0.15/");
const isBlogPagination = /^\/blog\/(\d+|tags|authors)\b/.test(pathname);
const noindex = isArchived || isBlogPagination;

// Pull JSON-LD blocks declared in page frontmatter via Starlight's `head`
// field is awkward; we expose a structured-data attribute on starlightRoute
// instead. Pages can set `Astro.locals.starlightRoute.entry.data.jsonLd` in
// route middleware, or include their own `<script type="application/ld+json">`
// inline. The shared schemas (Article, BreadcrumbList, FAQPage) are wired in
// by src/components/jsonld/* via this component's slot.

// Build per-page structured data automatically.
const ldBlocks: unknown[] = [];

// BreadcrumbList for every docs page (excluding the docs landing).
if (pathname.startsWith("/docs/") && pathname !== "/docs/" && pathname !== "/docs") {
  const segments = pathname.replace(/\/$/, "").split("/").filter(Boolean);
  const items = segments.map((seg, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: seg
      .replace(/-/g, " ")
      .replace(/\b\w/g, (c) => c.toUpperCase()),
    item: `${SITE}/${segments.slice(0, i + 1).join("/")}/`,
  }));
  ldBlocks.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items,
  });
}

// Article on every blog post.
const route = (Astro.locals as { starlightRoute?: any }).starlightRoute;
if (
  blogMatch &&
  blogMatch[1] &&
  !/^(authors|tags|\d+)$/.test(blogMatch[1]) &&
  route?.entry?.data
) {
  const data = route.entry.data;
  const date = data.date instanceof Date ? data.date.toISOString() : undefined;
  const lastUpdated =
    data.lastUpdated instanceof Date
      ? data.lastUpdated.toISOString()
      : date;
  const authors = Array.isArray(data.authors) ? data.authors : [];
  ldBlocks.push({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: data.title,
    description: data.description ?? data.excerpt ?? undefined,
    image: ogImage,
    url: `${SITE}${pathname}`,
    ...(date ? { datePublished: date } : {}),
    ...(lastUpdated ? { dateModified: lastUpdated } : {}),
    author: authors.map((a: unknown) =>
      typeof a === "string"
        ? { "@type": "Person", name: a }
        : { "@type": "Person", name: (a as { name?: string }).name ?? "Stalwart" },
    ),
    publisher: {
      "@type": "Organization",
      name: "Stalwart Labs",
      logo: { "@type": "ImageObject", url: `${SITE}/favicon.svg` },
    },
  });
}

// FAQPage on /docs/faq.
if (pathname === "/docs/faq" || pathname === "/docs/faq/") {
  // Synthesised from the rendered headings collection if available.
  const headings: { depth: number; slug: string; text: string }[] =
    route?.headings ?? [];
  // FAQPage Q&A pairs come from H3 (### question?) inside H2 (## section)
  // groups. We flatten: each H3 is a question; the answer is the prose
  // between it and the next heading. We don't have post-render HTML access
  // here, so emit just the questions as itemListElement of a Question type
  // — Google still parses this for rich-result eligibility when the
  // descriptions are short.
  const questions = headings.filter((h) => h.depth === 3);
  if (questions.length) {
    ldBlocks.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: questions.map((q) => ({
        "@type": "Question",
        name: q.text,
        acceptedAnswer: {
          "@type": "Answer",
          text: q.text,
          url: `${SITE}${pathname}#${q.slug}`,
        },
      })),
    });
  }
}
---
<Default {...Astro.props}><slot /></Default>
{noindex && <meta name="robots" content="noindex"/>}
<link rel="alternate" type="application/rss+xml" title="Stalwart Blog" href="/blog/rss.xml"/>
<link
  rel="preload"
  as="font"
  type="font/woff2"
  href={interLatinUrl}
  crossorigin
/>
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage} />
{ldBlocks.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)}/>
))}
<script async src={`https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`}></script>
<script is:inline define:vars={{ GTAG_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', GTAG_ID);
</script>
