---
---
<div class="cluster">
  <svg viewBox="0 0 480 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Stalwart cluster topology">
    <defs>
      <linearGradient id="line-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="var(--brand)" stop-opacity="0.7"/>
        <stop offset="100%" stop-color="var(--brand)" stop-opacity="0.15"/>
      </linearGradient>
      <radialGradient id="node-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="var(--brand)" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="var(--brand)" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- Edges -->
    <g class="edges" stroke="url(#line-grad)" stroke-width="1" fill="none">
      <line x1="240" y1="60" x2="100" y2="180"/>
      <line x1="240" y1="60" x2="380" y2="180"/>
      <line x1="240" y1="60" x2="240" y2="180"/>
      <line x1="100" y1="180" x2="240" y2="300"/>
      <line x1="380" y1="180" x2="240" y2="300"/>
      <line x1="240" y1="180" x2="240" y2="300"/>
      <line x1="100" y1="180" x2="380" y2="180"/>
      <line x1="100" y1="180" x2="240" y2="180"/>
      <line x1="240" y1="180" x2="380" y2="180"/>
    </g>

    <!-- Glows -->
    <g class="glows">
      <circle cx="240" cy="60" r="50" fill="url(#node-glow)"/>
      <circle cx="100" cy="180" r="50" fill="url(#node-glow)"/>
      <circle cx="240" cy="180" r="50" fill="url(#node-glow)"/>
      <circle cx="380" cy="180" r="50" fill="url(#node-glow)"/>
      <circle cx="240" cy="300" r="50" fill="url(#node-glow)"/>
    </g>

    <!-- Nodes -->
    <g class="nodes">
      <g class="node node-primary">
        <circle cx="240" cy="60" r="22"/>
        <text x="240" y="64" text-anchor="middle">SMTP</text>
      </g>
      <g class="node">
        <circle cx="100" cy="180" r="22"/>
        <text x="100" y="184" text-anchor="middle">JMAP</text>
      </g>
      <g class="node">
        <circle cx="240" cy="180" r="22"/>
        <text x="240" y="184" text-anchor="middle">DAV</text>
      </g>
      <g class="node">
        <circle cx="380" cy="180" r="22"/>
        <text x="380" y="184" text-anchor="middle">IMAP</text>
      </g>
      <g class="node node-primary">
        <circle cx="240" cy="300" r="22"/>
        <text x="240" y="304" text-anchor="middle">Store</text>
      </g>
    </g>

    <!-- Floating tags -->
    <g class="tags">
      <g class="tag" transform="translate(60 80)">
        <rect x="-58" y="-12" width="116" height="24" rx="12"/>
        <text x="0" y="4" text-anchor="middle">Zenoh P2P</text>
      </g>
      <g class="tag" transform="translate(420 80)">
        <rect x="-50" y="-12" width="100" height="24" rx="12"/>
        <text x="0" y="4" text-anchor="middle">Kafka</text>
      </g>
      <g class="tag" transform="translate(60 280)">
        <rect x="-50" y="-12" width="100" height="24" rx="12"/>
        <text x="0" y="4" text-anchor="middle">FoundationDB</text>
      </g>
      <g class="tag" transform="translate(420 280)">
        <rect x="-44" y="-12" width="88" height="24" rx="12"/>
        <text x="0" y="4" text-anchor="middle">S3</text>
      </g>
    </g>

    <!-- Pulse -->
    <circle class="pulse" cx="240" cy="60" r="22" fill="none" stroke="var(--brand)" stroke-width="1.5"/>
    <circle class="pulse pulse--2" cx="240" cy="300" r="22" fill="none" stroke="var(--brand)" stroke-width="1.5"/>
  </svg>
</div>

<style>
  .cluster {
    width: 100%;
    aspect-ratio: 480 / 360;
    position: relative;
  }
  .cluster svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .nodes circle {
    fill: var(--surface);
    stroke: var(--border-strong);
    stroke-width: 1.5;
  }
  .node-primary circle {
    fill: var(--brand-soft);
    stroke: var(--brand);
  }
  .nodes text {
    fill: var(--text);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
  }
  .tags rect {
    fill: var(--surface);
    stroke: var(--border);
    stroke-width: 1;
  }
  .tags text {
    fill: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.02em;
  }
  .edges {
    stroke-dasharray: 4 4;
  }

  @keyframes pulse {
    0%   { r: 22; opacity: 0.7; }
    100% { r: 50; opacity: 0; }
  }
  .pulse {
    transform-origin: center;
    animation: pulse 2.4s var(--ease-emph) infinite;
  }
  .pulse--2 {
    animation-delay: 1.2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse {
      animation: none;
      opacity: 0;
    }
  }
</style>
