---
<footer class="site-footer">
  <div class="container">
    <div class="cta-card">
      <div class="cta-card__bloom" aria-hidden="true"></div>
      <div class="cta-card__content">
        <span class="eyebrow">Get started</span>
        <h2 class="cta-card__title">{cta}</h2>
        <p class="cta-card__sub">{ctaSub}</p>
      </div>
      <div class="cta-card__actions">
        <a class="btn btn-primary btn-arrow" href={ctaLink}>{ctaButton}</a>
        <a class="btn btn-ghost" href="/pricing">See pricing</a>
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <Logo />
        <address class="footer-address">
          128 City Road<br/>
          London, UK
        </address>
        <a class="link-arrow" href="mailto:hello@stalw.art">hello@stalw.art</a>
        <ul class="footer-socials">
          {socials.map(s => (
            <li>
              <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={s.path}/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <span class="footer-col__title">Platform</span>
        <ul>{platform.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div class="footer-col">
        <span class="footer-col__title">Editions</span>
        <ul>{editions.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div class="footer-col">
        <span class="footer-col__title">Solutions</span>
        <ul>{solutions.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div class="footer-col">
        <span class="footer-col__title">Company</span>
        <ul>{company.map(l => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Stalwart Labs LLC. All rights reserved.</span>
      <a href="/legal">Legal</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--section-y);
    padding-bottom: 3rem;
    border-top: 1px solid var(--border);
    background: linear-gradient(to bottom, var(--bg) 0%, var(--bg-elev) 100%);
  }

  .cta-card {
    position: relative;
    overflow: hidden;
    margin-top: -7rem;
    padding: clamp(2.5rem, 5vw, 4rem);
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--surface) 0%, var(--surface-2) 100%);
    border: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--shadow-2);
    isolation: isolate;
  }
  .cta-card__bloom {
    position: absolute;
    inset: -50%;
    background: radial-gradient(circle at 80% 30%, var(--brand-glow) 0%, transparent 45%);
    z-index: -1;
    pointer-events: none;
  }
  .cta-card__content {
    flex: 1 1 460px;
  }
  .cta-card__title {
    font-size: clamp(1.5rem, 2.4vw + 0.6rem, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-top: 0.75rem;
    max-width: 22ch;
  }
  .cta-card__sub {
    margin-top: 0.75rem;
    color: var(--text-muted);
    max-width: 50ch;
  }
  .cta-card__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer-grid {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 2rem;
  }
  @media (min-width: 720px) {
    .footer-grid {
      grid-template-columns: 1.4fr repeat(4, 1fr);
    }
  }
  .footer-brand {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    max-width: 320px;
  }
  @media (min-width: 720px) {
    .footer-brand {
      grid-column: auto;
    }
  }
  .footer-address {
    color: var(--text-muted);
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .footer-socials {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .footer-socials li a {
    width: 32px;
    height: 32px;
    display: inline-grid;
    place-items: center;
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    border: 1px solid var(--border);
    transition: color var(--t-fast) var(--ease), border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);
  }
  .footer-socials li a:hover {
    color: var(--brand);
    border-color: var(--brand);
    background: var(--brand-soft);
  }

  .footer-col__title {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-dim);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-col ul li a {
    color: var(--text-muted);
    font-size: 0.9375rem;
    transition: color var(--t-fast) var(--ease);
  }
  .footer-col ul li a:hover {
    color: var(--text);
  }

  .footer-bottom {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-dim);
    font-size: 0.875rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-bottom a {
    color: var(--text-muted);
  }
  .footer-bottom a:hover {
    color: var(--text);
  }
</style>
