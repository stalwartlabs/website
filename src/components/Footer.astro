---
import Logo from "./Logo.astro";

interface Props {
  cta?: string;
  ctaSub?: string;
  ctaButton?: string;
  ctaLink?: string;
}

const {
  cta = "Ready to run a modern mail and collaboration server?",
  ctaSub = "Install Stalwart in minutes, then keep it running for years.",
  ctaButton = "Get Stalwart",
  ctaLink = "/docs/install/get-started",
} = Astro.props;

const platform = [
  { href: "/mail-server", label: "Mail Server" },
  { href: "/collaboration", label: "Collaboration" },
  { href: "/mta", label: "MTA" },
  { href: "/anti-spam", label: "Anti-spam" },
  { href: "/architecture", label: "Architecture" },
  { href: "/integrations", label: "Integrations" },
];
const editions = [
  { href: "/enterprise", label: "Enterprise" },
  { href: "/open-source", label: "Community" },
  { href: "/compare", label: "Compare" },
  { href: "/pricing", label: "Pricing" },
];
const solutions = [
  { href: "/managed-email", label: "Managed e-mail" },
  { href: "/migration", label: "Migration" },
];
const company = [
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/support", label: "Support" },
  { href: "/contact", label: "Contact" },
  { href: "/legal", label: "Legal" },
];

