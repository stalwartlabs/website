---
// One identity at the centre, four protocol pillars (Mail, Calendar,
// Contacts, Files) around it, sharing the same auth and quota base.
---
<div class="cu">
  <svg viewBox="0 0 720 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Unified identity for mail, calendar, contacts and files">
    <defs>
      <radialGradient id="cu-glow" cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="var(--brand)" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="var(--brand)" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <rect x="0" y="0" width="720" height="460" fill="url(#cu-glow)"/>

    <!-- Center: identity -->
    <g transform="translate(360 230)">
      <circle r="84" fill="var(--brand-soft)" stroke="var(--brand)" stroke-width="1.5"/>
      <text class="cu__id-name" y="-6" text-anchor="middle">alice@example.com</text>
      <text class="cu__id-sub"  y="14" text-anchor="middle">one identity</text>
    </g>

    <!-- Four pillar tiles -->
    <g class="cu__pill" transform="translate(140 130)">
      <rect x="-100" y="-44" width="200" height="88" rx="14"/>
      <text class="cu__pill-icon" y="-20" text-anchor="middle">✉</text>
      <text class="cu__pill-name" y="2" text-anchor="middle">Mail</text>
      <text class="cu__pill-sub"  y="20" text-anchor="middle">JMAP · IMAP · POP3</text>
    </g>
    <g class="cu__pill" transform="translate(580 130)">
      <rect x="-100" y="-44" width="200" height="88" rx="14"/>
      <text class="cu__pill-icon" y="-20" text-anchor="middle">▣</text>
      <text class="cu__pill-name" y="2" text-anchor="middle">Calendar</text>
      <text class="cu__pill-sub"  y="20" text-anchor="middle">CalDAV · JMAP for Calendars</text>
    </g>
    <g class="cu__pill" transform="translate(140 330)">
      <rect x="-100" y="-44" width="200" height="88" rx="14"/>
      <text class="cu__pill-icon" y="-20" text-anchor="middle">☷</text>
      <text class="cu__pill-name" y="2" text-anchor="middle">Contacts</text>
      <text class="cu__pill-sub"  y="20" text-anchor="middle">CardDAV · JMAP for Contacts</text>
    </g>
    <g class="cu__pill" transform="translate(580 330)">
      <rect x="-100" y="-44" width="200" height="88" rx="14"/>
      <text class="cu__pill-icon" y="-20" text-anchor="middle">▤</text>
      <text class="cu__pill-name" y="2" text-anchor="middle">Files</text>
      <text class="cu__pill-sub"  y="20" text-anchor="middle">WebDAV · JMAP for Files</text>
    </g>

    <!-- Connecting lines from identity to each pillar -->
    <g class="cu__lines" stroke="var(--brand)" stroke-opacity="0.5" stroke-width="1.5" stroke-dasharray="4 4">
      <line x1="294" y1="190" x2="240" y2="160"/>
      <line x1="426" y1="190" x2="480" y2="160"/>
      <line x1="294" y1="270" x2="240" y2="300"/>
      <line x1="426" y1="270" x2="480" y2="300"/>
    </g>

    <text x="40" y="40" class="cu__title">One identity, every collaboration surface</text>
  </svg>
</div>

<style>
  .cu {
    width: 100%;
    aspect-ratio: 720 / 460;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(0.5rem, 1.5vw, 1rem);
    box-shadow: var(--shadow-1);
  }
  .cu svg { width: 100%; height: 100%; overflow: visible; }
  .cu__title {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cu__id-name {
    fill: var(--brand);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    dominant-baseline: middle;
  }
  .cu__id-sub {
    fill: var(--brand);
    font-family: var(--font-mono);
    font-size: 10px;
    dominant-baseline: middle;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .cu__pill rect {
    fill: var(--surface);
    stroke: var(--border-strong);
    stroke-width: 1;
  }
  .cu__pill-icon {
    fill: var(--brand);
    font-size: 22px;
    font-weight: 700;
    dominant-baseline: middle;
  }
  .cu__pill-name {
    fill: var(--text);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    dominant-baseline: middle;
  }
  .cu__pill-sub {
    fill: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    dominant-baseline: middle;
    letter-spacing: 0.04em;
  }
</style>
