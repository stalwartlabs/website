---
import Default from "@astrojs/starlight/components/PageFrame.astro";
import MarketingFooter from "./Footer.astro";
---
<Default {...Astro.props}>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>
<MarketingFooter hideCta />

<style is:global>
  /* Starlight's .page wrapper sets min-height: 100vh and uses flex-direction:
     column. We render the marketing footer outside that wrapper so it spans
     the full window width instead of being squeezed between the sidebar and
     the table of contents. */
  body > .page {
    min-height: auto;
  }
</style>
