---
// FTRL-Proximal classifier pipeline: tokeniser -> feature hash -> sparse
// weights -> score; with a feedback loop arrow back from "user marks
// spam/ham", and an address-book pre-classification arrow.
---
<div class="cls">
  <svg viewBox="0 0 720 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="FTRL-Proximal classifier pipeline">
    <defs>
      <linearGradient id="cls-flow" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="var(--brand)" stop-opacity="0.55"/>
        <stop offset="100%" stop-color="var(--brand)" stop-opacity="0.15"/>
      </linearGradient>
      <marker id="cls-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M0 0 L10 5 L0 10 z" fill="var(--brand)" opacity="0.85"/>
      </marker>
    </defs>

    <!-- Input -->
    <g class="cls__node" transform="translate(80 230)">
      <rect x="-50" y="-26" width="100" height="52" rx="10"/>
      <text class="cls__node-name">Message</text>
      <text class="cls__node-sub" y="14">headers + body</text>
    </g>

    <!-- Stage 1: Tokenise -->
    <g class="cls__node" transform="translate(220 230)">
      <rect x="-50" y="-26" width="100" height="52" rx="10"/>
      <text class="cls__node-name">Tokenise</text>
      <text class="cls__node-sub" y="14">words + n-grams</text>
    </g>

    <!-- Stage 2: Feature hash -->
    <g class="cls__node" transform="translate(360 230)">
      <rect x="-58" y="-26" width="116" height="52" rx="10"/>
      <text class="cls__node-name">Feature hash</text>
      <text class="cls__node-sub" y="14">cuckoo · 524288</text>
    </g>

    <!-- Stage 3: FTRL weights -->
    <g class="cls__node cls__node--brand" transform="translate(510 230)">
      <rect x="-58" y="-30" width="116" height="60" rx="10"/>
      <text class="cls__node-name">FTRL weights</text>
      <text class="cls__node-sub" y="14">L1 + L2 sparse</text>
    </g>

    <!-- Output: Score -->
    <g class="cls__node cls__node--score" transform="translate(640 230)">
      <rect x="-44" y="-26" width="88" height="52" rx="26"/>
      <text class="cls__node-name">Score</text>
      <text class="cls__node-sub" y="14">[-5 ... +5]</text>
    </g>

    <!-- Edges along the spine -->
    <g fill="none" stroke="url(#cls-flow)" stroke-width="2" marker-end="url(#cls-arrow)">
      <line x1="130" y1="230" x2="170" y2="230"/>
      <line x1="270" y1="230" x2="302" y2="230"/>
      <line x1="418" y1="230" x2="452" y2="230"/>
      <line x1="568" y1="230" x2="596" y2="230"/>
    </g>

    <!-- Top: address-book pre-classification arrow -->
    <g class="cls__addressbook" transform="translate(220 90)">
      <rect x="-90" y="-26" width="180" height="52" rx="10"/>
      <text class="cls__node-name">Recipient address book</text>
      <text class="cls__node-sub" y="14">known correspondent?</text>
    </g>
    <path class="cls__pre" d="M 220 116 C 220 170, 280 180, 340 200" fill="none" stroke="var(--brand)" stroke-width="1.5" stroke-dasharray="4 4" marker-end="url(#cls-arrow)"/>
    <text class="cls__edge-label" x="240" y="180">weighted -2.0 toward ham</text>

    <!-- Bottom: feedback loop from user -->
    <g class="cls__user" transform="translate(420 380)">
      <rect x="-110" y="-26" width="220" height="52" rx="10"/>
      <text class="cls__node-name">User marks spam / ham</text>
      <text class="cls__node-sub" y="14">retrain online</text>
    </g>
    <path class="cls__feedback" d="M 510 354 C 510 320, 510 290, 510 264" fill="none" stroke="var(--brand)" stroke-width="1.5" stroke-dasharray="3 4" marker-end="url(#cls-arrow)"/>
    <text class="cls__edge-label cls__edge-label--brand" x="520" y="320">retrain</text>

    <text x="40" y="40" class="cls__title">FTRL-Proximal pipeline</text>
  </svg>
</div>

<style>
  .cls {
    width: 100%;
    aspect-ratio: 720 / 460;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(0.5rem, 1.5vw, 1rem);
    box-shadow: var(--shadow-1);
  }
  .cls svg { width: 100%; height: 100%; overflow: visible; }

  .cls__title {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .cls__caption {
    font-family: var(--font-sans);
    font-size: 11px;
    fill: var(--text-muted);
  }

  .cls__node rect, .cls__addressbook rect, .cls__user rect {
    fill: var(--surface-2);
    stroke: var(--border-strong);
    stroke-width: 1;
  }
  .cls__node-name {
    fill: var(--text);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-anchor: middle;
    dominant-baseline: middle;
  }
  .cls__node-sub {
    fill: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 9px;
    text-anchor: middle;
    dominant-baseline: middle;
    letter-spacing: 0.04em;
  }
  .cls__node--brand rect {
    fill: var(--brand-soft);
    stroke: var(--brand);
  }
  .cls__node--brand .cls__node-name { fill: var(--brand); }
  .cls__node--score rect {
    fill: var(--brand);
    stroke: var(--brand);
  }
  .cls__node--score .cls__node-name { fill: #fff; }
  .cls__node--score .cls__node-sub { fill: rgba(255,255,255,0.85); }

  .cls__edge-label {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .cls__edge-label--brand { fill: var(--brand); }
</style>
