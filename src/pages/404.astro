---
import Base from "../layouts/Base.astro";
---
<Base
  title="Page not found - Stalwart"
  description="The page you were looking for could not be found. Search the Stalwart documentation, blog, and site below."
  noindex
>
  <section class="not-found">
    <div class="container not-found__inner">
      <p class="eyebrow">404</p>
      <h1 class="not-found__title">We couldn't find that page</h1>
      <p class="not-found__lead">
        The link may be out of date, or the page might have moved. Try the
        search below, or jump to one of the popular destinations.
      </p>

      <div class="not-found__search">
        <input
          type="search"
          id="pagefind-search"
          placeholder="Search the docs, blog, and site..."
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the site"
        />
        <div id="pagefind-results" class="not-found__results" aria-live="polite"></div>
      </div>

      <ul class="not-found__links">
        <li><a href="/docs/install/">Getting started</a></li>
        <li><a href="/docs/storage/">Storage</a></li>
        <li><a href="/docs/mta/">MTA</a></li>
        <li><a href="/docs/collaboration/">Collaboration</a></li>
        <li><a href="/docs/spamfilter/">Spam filter</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>
  </section>
</Base>

<style>
  .not-found {
    padding: var(--section-y) 0;
  }
  .not-found__inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }
  .not-found__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-top: 0.5rem;
    letter-spacing: -0.02em;
  }
  .not-found__lead {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 1.0625rem;
  }
  .not-found__search {
    margin-top: 2.5rem;
    text-align: left;
  }
  #pagefind-search {
    width: 100%;
    padding: 0.85rem 1rem;
    font-size: 1rem;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);
  }
  #pagefind-search:focus {
    outline: none;
    border-color: var(--brand);
    background: var(--bg-elev);
  }
  .not-found__results {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .not-found__results .pf-result {
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    text-decoration: none;
    color: var(--text);
    display: block;
    transition: border-color var(--t-fast) var(--ease);
  }
  .not-found__results .pf-result:hover {
    border-color: var(--brand);
  }
  .not-found__results .pf-result strong {
    display: block;
    color: var(--text);
    font-size: 0.9375rem;
    margin-bottom: 0.2rem;
  }
  .not-found__results .pf-result span {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .not-found__results .pf-result mark {
    background: var(--brand-soft);
    color: var(--brand);
    padding: 0 2px;
    border-radius: 3px;
  }
  .not-found__results .pf-empty {
    color: var(--text-dim);
    font-size: 0.9375rem;
    padding: 0.5rem 0;
  }
  .not-found__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 2.5rem;
  }
  .not-found__links li a {
    display: inline-flex;
    padding: 0.45rem 0.95rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color var(--t-fast) var(--ease), border-color var(--t-fast) var(--ease);
  }
  .not-found__links li a:hover {
    color: var(--brand);
    border-color: var(--brand);
  }
</style>

<script>
  const input = document.getElementById("pagefind-search") as HTMLInputElement | null;
  const out = document.getElementById("pagefind-results");
  if (!input || !out) {
    /* nothing to do */
  } else {
    type PagefindResultDataExcerpt = { excerpt: string };
    type PagefindResult = {
      data: () => Promise<{
        url: string;
        meta?: { title?: string };
        excerpt?: string;
        sub_results?: PagefindResultDataExcerpt[];
      }>;
    };
    type PagefindAPI = {
      search: (q: string) => Promise<{ results: PagefindResult[] }>;
    };

    let pagefind: PagefindAPI | null = null;
    let lastQuery = "";

    async function loadPagefind() {
      if (pagefind) return pagefind;
      // Pagefind ships into dist/pagefind/ during `astro build` and isn't
      // present in `astro dev`. We use `new Function('return import(...)')`
      // to bypass Vite's static module-graph analysis entirely; otherwise
      // the dev server fails to resolve the path at compile time.
      const dynamicImport = new Function(
        "s",
        "return import(s)",
      ) as (s: string) => Promise<unknown>;
      try {
        const mod = await dynamicImport("/pagefind/pagefind.js");
        pagefind = mod as PagefindAPI;
        return pagefind;
      } catch {
        out!.innerHTML =
          '<p class="pf-empty">Search is only available after <code>npm run build</code> (Pagefind index is generated during the production build).</p>';
        return null;
      }
    }

    function escape(html: string): string {
      const div = document.createElement("div");
      div.textContent = html;
      return div.innerHTML;
    }

    async function runSearch(query: string) {
      if (!query.trim()) {
        out!.innerHTML = "";
        return;
      }
      const pf = await loadPagefind();
      if (!pf) return;
      const search = await pf.search(query);
      if (search.results.length === 0) {
        out!.innerHTML = '<p class="pf-empty">No results.</p>';
        return;
      }
      const top = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
      out!.innerHTML = top
        .map(
          (d) =>
            `<a class="pf-result" href="${escape(d.url)}"><strong>${escape(d.meta?.title ?? d.url)}</strong><span>${d.excerpt ?? ""}</span></a>`,
        )
        .join("");
    }

    let timer: number | undefined;
    input.addEventListener("input", () => {
      const q = input.value;
      if (q === lastQuery) return;
      lastQuery = q;
      window.clearTimeout(timer);
      timer = window.setTimeout(() => runSearch(q), 120);
    });
    input.focus();
  }
</script>
